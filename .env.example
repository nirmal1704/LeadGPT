GROQ_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
CAPSOLVER_API_KEY=
GROQ_REQUESTS_PER_MINUTE=28
GROQ_TOKENS_PER_MINUTE=7500
GROQ_MODEL=openai/gpt-oss-120b
MEMORY_SIMILARITY_THRESHOLD=0.85
# Max simultaneous browser contexts in batch_extract(). On Oracle Cloud ARM
# (12GB RAM, worker capped at 3g), 2 concurrent contexts is safe.
MAX_CONCURRENT_PAGES=2
